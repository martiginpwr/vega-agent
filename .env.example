OLLAMA_BASE_URL=http://127.0.0.1:11434
VEGA_DEFAULT_MODEL=
VEGA_DATABASE_PATH=storage/vega.db
# Pull the local small classifier/grounding/verifier model first:
# ollama pull hf.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF
VEGA_MEMORY_MODEL=hf.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF:latest
# Grounding is stricter and may use a stronger local model. Higher latency is acceptable here.
VEGA_MEMORY_GROUNDING_MODEL=qwen3.5:9b
VEGA_MEMORY_VERIFIER_MODEL=hf.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF:latest
# Optional: use your local Qwen embedding model for memory dedupe/retrieval.
VEGA_EMBEDDING_MODEL=
